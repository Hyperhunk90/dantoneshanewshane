# Resend transactional email (required for the quote & contact forms)
# Create an API key at https://resend.com/api-keys
RESEND_API_KEY=YOUR_API_KEY

# Where lead emails are delivered
LEAD_TO_EMAIL=SBL@Southernbucklawn.com

# Verified sender on your Resend account.
# This address must be on a domain you have verified in Resend (southernbucklawn.com),
# or Resend will reject the message and leads will not send.
LEAD_FROM_EMAIL=Noreply@Southernbucklawn.com

# Public site URL (used for canonical tags + sitemap)
NEXT_PUBLIC_SITE_URL=https://southernbucklawn.com
